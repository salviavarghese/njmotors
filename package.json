{
  "name": "njmotors",
  "version": "1.0.0",
  "description": "NJ Motors - used car dealership site (Payload 3 + Next.js)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed.ts",
    "seed:makes": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seedMakes.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.37.0",
    "@payloadcms/next": "3.37.0",
    "@payloadcms/payload-cloud": "3.37.0",
    "@payloadcms/richtext-lexical": "3.37.0",
    "@payloadcms/storage-vercel-blob": "3.37.0",
    "@payloadcms/ui": "3.37.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "graphql": "^16.8.1",
    "gsap": "^3.12.5",
    "lenis": "^1.1.13",
    "lucide-react": "^0.456.0",
    "next": "^15.5.19",
    "payload": "3.37.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^4.0.0",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
