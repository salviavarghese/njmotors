# ---- Neon (use the POOLED connection string) ----
DATABASE_URI=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require

# ---- Payload ----
# Any long random string. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=changeme-long-random-string

# ---- Vercel Blob (from your Blob store) ----
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# ---- Resend (transactional email) ----
RESEND_API_KEY=re_xxxxxxxx
# The verified "from" address. For a demo, Resend's onboarding@resend.dev works.
ENQUIRY_FROM_EMAIL=onboarding@resend.dev
# Where NJ Motors actually receives the lead.
ENQUIRY_TO_EMAIL=you@example.com
